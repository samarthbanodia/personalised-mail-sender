# --- Agent service environment ---

# OpenRouter API key (https://openrouter.ai/keys). Required to call models.
OPENROUTER_API_KEY=

# Optional overrides
OPENROUTER_BASE_URL=https://openrouter.ai/api/v1
DEFAULT_RESUME_MODEL=openai/gpt-4o-mini
DEFAULT_PERSONALIZATION_MODEL=anthropic/claude-3.5-sonnet
REQUEST_TIMEOUT_SECONDS=120

# OpenRouter attribution (shown on your OpenRouter dashboard)
APP_TITLE=Personalized Mass AI Mailer
APP_REFERER=http://localhost:3000

# Comma-separated list of web origins allowed to call this service (CORS)
CORS_ALLOW_ORIGINS=http://localhost:3000
